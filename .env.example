# NebulaGraph
NEBULA_HOST=127.0.0.1
NEBULA_PORT=9669
NEBULA_USER=root
NEBULA_PASSWORD=nebula
NEBULA_SPACE=intelligence_graph

# LLM (OpenAI-compatible endpoint — OpenCode Zen)
LLM_BASE_URL=https://opencode.ai/zen/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-5.1-codex-mini
LLM_TEMPERATURE=0.0

# Relational store (evidence, registry, review queue)
EVIDENCE_DATABASE_URL=sqlite:///./evidence_store.db

# Celery (background pipeline)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Evidence storage
EVIDENCE_DIR=./evidence_store

# Confidence gates
CONF_AUTO_ACCEPT=0.85
CONF_REVIEW_MIN=0.50

# Entity resolution
ER_FUZZY_AUTO=0.93
ER_FUZZY_CANDIDATE=0.75
ER_USE_EMBEDDINGS=true
ER_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Ingestion pipeline
# inline (default): pipeline runs in background threads inside the API process
#                   — no Redis/Celery needed, perfect for dev & single-node.
# celery:           dispatch to the Celery chain (requires Redis + a running
#                   worker: celery -A worker.pipeline worker --loglevel=info)
INGEST_MODE=inline
INGEST_WORKERS=2

# API
GRAPH_EXPLORER_DATA_DIR=./data
